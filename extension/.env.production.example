# TIP-012 — Build extension bản PRODUCTION (trỏ về Vercel).
# Copy file này thành `extension/.env.production` (đã gitignore) rồi: npm run build:prod
# Chỉ anon key + URL công khai. TUYỆT ĐỐI KHÔNG service_role.

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase anon key>
NEXT_PUBLIC_SITE_URL=https://<frontend>.vercel.app
NEXT_PUBLIC_BACKEND_URL=https://<backend>.vercel.app
