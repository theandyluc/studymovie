{
  "manifest_version": 3,
  "name": "StudyMovie",
  "version": "1.1.3",
  "description": "Học tiếng Anh qua YouTube với phụ đề song ngữ + ôn từ vựng.",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["*://*.youtube.com/*", "http://localhost:3000/*", "https://app.studymovie.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "StudyMovie",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*", "https://app.studymovie.com/*"],
      "js": ["content/auth-bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/yt-intercept.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
