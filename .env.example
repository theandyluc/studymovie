# StudyMovie — .env.example
# Copy thành .env và điền giá trị thật. KHÔNG commit .env.
# Lúc bàn giao (Cách B): đổi toàn bộ sang tài khoản của khách.

# --- Supabase (region: Singapore) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # CHỈ dùng ở backend/serverless, không lộ client

# --- Supabase cho FRONTEND (client) — phải có tiền tố NEXT_PUBLIC ---
# Giá trị = giống SUPABASE_URL / SUPABASE_ANON_KEY ở trên. TUYỆT ĐỐI không đặt service_role ở đây.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Google OAuth (Google Cloud Console) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- SePay (thanh toán) ---
SEPAY_API_KEY=
SEPAY_WEBHOOK_SECRET=

# --- VietQR (thông tin tài khoản nhận) ---
VIETQR_BANK_CODE=
VIETQR_ACCOUNT_NO=
VIETQR_ACCOUNT_NAME=

# --- Backend API base URL (frontend + extension gọi vào) ---
NEXT_PUBLIC_BACKEND_URL=

# --- Domain ---
NEXT_PUBLIC_SITE_URL=https://studymovie.com
