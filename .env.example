# StudyMovie — .env.example
# Copy thành .env và điền giá trị thật. KHÔNG commit .env.
# Lúc bàn giao (Cách B): đổi toàn bộ sang tài khoản của khách.
#
# ── DEPLOY VERCEL (TIP-012) — set env trên Vercel Dashboard, KHÔNG commit ──
# Project FRONTEND (web/frontend): NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY,
#   NEXT_PUBLIC_BACKEND_URL (= URL backend Vercel), NEXT_PUBLIC_SITE_URL (= https://app.studymovie.com),
#   NEXT_PUBLIC_BLOG_URL, NEXT_PUBLIC_PAYWALL_REDIRECT.
# Project BACKEND  (web/backend) : SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY,
#   NEXT_PUBLIC_SITE_URL (= https://app.studymovie.com — web app, dùng cho CORS),
#   + thanh toán (TIP-013): SEPAY_API_KEY, BANK_ID, BANK_ACCOUNT_NO, BANK_ACCOUNT_NAME,
#     VIETQR_TEMPLATE, PRO_PRICE, PRO_DURATION_DAYS.
# Extension production: dùng extension/.env.production (xem extension/.env.production.example).

# --- Supabase (region: Singapore) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # CHỈ dùng ở backend/serverless, không lộ client

# --- Supabase cho FRONTEND (client) — phải có tiền tố NEXT_PUBLIC ---
# Giá trị = giống SUPABASE_URL / SUPABASE_ANON_KEY ở trên. TUYỆT ĐỐI không đặt service_role ở đây.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Google OAuth (Google Cloud Console) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Thanh toán Pro (TIP-013) — set ở Vercel project BACKEND, KHÔNG commit ---
# SEPAY_API_KEY: webhook verify header `Authorization: Apikey <key>` (SePay dashboard cấp).
SEPAY_API_KEY=
# Tài khoản nhận (VietQR): BANK_ID = mã ngân hàng VietQR (vd MB / 970422), số & tên TK.
BANK_ID=
BANK_ACCOUNT_NO=
BANK_ACCOUNT_NAME=
VIETQR_TEMPLATE=compact2   # mẫu ảnh VietQR (compact2/compact/qr_only)
# Giá + thời hạn gói Pro (đổi ở đây, KHÔNG hardcode trong code).
PRO_PRICE=49000
PRO_DURATION_DAYS=30

# --- Backend API base URL (frontend + extension gọi vào) ---
NEXT_PUBLIC_BACKEND_URL=

# --- Domain ---
# Web app = subdomain app.studymovie.com (apex studymovie.com = landing page của khách, repo khác).
NEXT_PUBLIC_SITE_URL=https://app.studymovie.com
# Blog (TIP-019a): /blog redirect tới URL này (mặc định nếu trống). Đặt ở Vercel project FRONTEND.
# Blog nằm ở landing của khách (host khác app) → giữ studymovie.com/blog, không trùng app.
NEXT_PUBLIC_BLOG_URL=https://studymovie.com/blog
# Paywall (TIP-019b): hết trial + chưa trả → redirect tới đây (mặc định /thanh-toan). Project FRONTEND.
NEXT_PUBLIC_PAYWALL_REDIRECT=/thanh-toan

# --- Tùy chọn (có default, không bắt buộc) ---
# PORT: cổng backend khi chạy local (mặc định 8787). Trên Vercel không cần.
# PORT=8787
# DICT_LIMIT: giới hạn số dòng khi seed từ điển (supabase/seed/import_dictionary.mjs), để trống = tất cả.
# DICT_LIMIT=
