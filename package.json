{
  "name": "studymovie",
  "version": "0.0.1",
  "private": true,
  "description": "StudyMovie monorepo — Chrome Extension (MV3) + Web (Next.js) + Backend API (Hono) + Supabase.",
  "workspaces": [
    "web/frontend",
    "web/backend",
    "extension"
  ],
  "engines": {
    "node": ">=20"
